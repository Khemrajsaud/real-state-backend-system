{
 
  "compilerOptions": {
    // File Layout
     "rootDir": "./src",
     "outDir": "./dist",

   "target": "ES2022",
    "module": "CommonJS",                
   
    "esModuleInterop": true,                
    "verbatimModuleSyntax": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": [],
   
  




  },

  "include":["src/**/*.ts"],
  "exclude": ["node_modules"]
}
