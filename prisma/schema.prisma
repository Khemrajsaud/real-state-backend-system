
generator client {
  provider        = "prisma-client-js"
}

datasource db {
  provider = "postgresql"

}


model User {
  id        Int       @id @default(autoincrement())
  name      String
  email     String    @unique
  password  String
  phone     String
  otpCode   String?   
  otpExpiry DateTime? 
  avatar    String?   // 👈 Add this line to store the Cloudinary profile picture URL
  dob       DateTime? // 👈 Optional: Add this line if you want to store Date of Birth
  createdAt DateTime  @default(now())
}


model TokenBlocklist {
  id        Int      @id @default(autoincrement())
  token     String   @unique
  createdAt DateTime @default(now())
}
model Admins {
  id        Int      @id @default(autoincrement())
  username  String   @unique  
  password  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model property_inquiries {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  phone     String
  message   String
  createdAt DateTime @default(now())
}

model Banner {
  id        Int      @id @default(autoincrement())
  title     String?  // Optional name/title for the banner
  imageUrl  String   // The image link generated by Cloudinary
  publicId  String   // Required to delete the file from Cloudinary later
  createdAt DateTime @default(now())
}




model properties {
  id                 Int                  @id @default(autoincrement())
  title              String
  description        String
  price              Float
  address            String               // e.g., "New Baneshwor, Kathmandu"
  locationLink       String?              // Google Maps URL pin string
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt

  // Category Relation Mapping
  categoryId         Int
  category           category             @relation(fields: [categoryId], references: [id])

  // Status Relation Mapping
  statusId           Int
  status             property_status      @relation(fields: [statusId], references: [id])

  // Connected Media & Feature Sub-arrays
  images             property_images[]
  videos             property_videos[]
  documents          property_documents[]
  property_amenities property_amenities[]
}

// ==========================================
// 2. PROPERTY LOOKUP/METADATA TABLES
// ==========================================

model category {
  id         Int          @id @default(autoincrement())
  name       String       @unique // "House", "Land", "Flats", "Office Space", "Shop Space", "Apartment"
  iconUrl    String?      // Optional CDN path or design icon class identifier
  properties properties[]
}

model property_status {
  id         Int          @id @default(autoincrement())
  name       String       @unique // "Available", "Under Construction", "Sold"
  properties properties[]
}

model amenities {
  id                 Int                  @id @default(autoincrement())
  name               String               @unique // "Swimming Pool", "Gym", "Garage", "Elevator"
  property_amenities property_amenities[]
}

// Many-to-Many Join Bridge Table for Properties <-> Amenities
model property_amenities {
  id         Int        @id @default(autoincrement())
  propertyId Int
  amenityId  Int
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  amenity    amenities  @relation(fields: [amenityId], references: [id], onDelete: Cascade)
}

// ==========================================
// 3. MEDIA & ATTACHMENTS SUB-STORAGES
// ==========================================

model property_images {
  id         Int        @id @default(autoincrement())
  propertyId Int
  image_url  String     // Cloudinary direct file URL string 
  publicId   String     // Cloudinary asset identifier (needed for secure deletions)
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model property_videos {
  id         Int        @id @default(autoincrement())
  propertyId Int
  video_url  String     // Video Hosting destination URL link
  publicId   String     // Cloudinary asset identifier (needed for secure deletions)
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

model property_documents {
  id         Int        @id @default(autoincrement())
  propertyId Int
  doc_url    String     // Secure CDN Document Download Link
  doc_name   String     // Original file metadata name (e.g., "Land_Deed.pdf")
  publicId   String     // Cloudinary asset identifier (needed for secure deletions)
  property   properties @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}


model testimonial {
  id         Int      @id @default(autoincrement())
  clientName String
  role       String   // e.g., "Homeowner", "Property Buyer", "CEO"
  company    String?  // Optional: e.g., "Google"
  message    String   // The actual review text
  rating     Int      // e.g., 1 to 5 stars
  avatarUrl  String?  // Cloudinary image link
  publicId   String?  // Cloudinary asset ID for cleaning up storage
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model faq {
  id        Int      @id @default(autoincrement())
  question  String
  answer    String
  category  String   @default("General") // e.g., "Buying", "Rentals", "Legal"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Subscriber {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Favorite {
  id         Int      @id @default(autoincrement())
  userId     Int      // Relates to your User model ID
  propertyId Int      // Relates to your Property model ID
  createdAt  DateTime @default(now())

  @@unique([userId, propertyId]) // Prevents a user from favoriting the same property twice
}